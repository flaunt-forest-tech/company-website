# Resend Email Service API Key
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Flaunt Forest <noreply@flauntforest.com>
CONTACT_TO_EMAIL=flauntforesttech@gmail.com

# Optional: Redis connection for production rate limiting
# REDIS_URL=redis://user:password@host:port
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_TLS_INSECURE_SKIP_VERIFY=false

# Current environment
NODE_ENV=development

# Website domain (for sitemap and other configs)
# NEXT_PUBLIC_SITE_URL=https://flauntforest.com
# ALLOWED_ORIGINS=https://flauntforest.com,https://www.flauntforest.com

# Optional: send instant lead alerts to Slack / Discord / Teams compatible webhooks
# LEAD_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
